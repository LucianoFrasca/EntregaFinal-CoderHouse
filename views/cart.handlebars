<h1 style="color: #2c3e50; text-align: center; border-bottom: 2px solid #eaeaea; padding-bottom: 15px;">Tu Carrito de Compras</h1>

<div style="margin-top: 30px;">
    {{#if cart.products.length}}
        {{#each cart.products}}
            <div style="background-color: #fff; border: 1px solid #eee; border-radius: 8px; padding: 15px; margin-bottom: 10px; display: flex; justify-content: space-between; align-items: center; border-left: 5px solid #eaeaea;">
                <div>
                    <h3 style="margin: 0 0 5px 0; color: #333;">{{this.auto.modelo}}</h3>
                    <p style="margin: 0; color: #666; font-size: 0.9em;">Precio unitario: <strong>${{this.auto.precio}}</strong> (Categoría: {{this.auto.categoria}})</p>
                </div>
                <div style="display: flex; align-items: center; gap: 20px;">
                    <span style="font-size: 1.2em; font-weight: bold; background-color: #eaeaea; padding: 5px 15px; border-radius: 20px;">
                        Cantidad: {{this.quantity}}
                    </span>
                    <button onclick="eliminarDelCarrito('{{this.auto._id}}')" style="padding: 8px 15px; background-color: #f44336; color: white; cursor: pointer; border: none; border-radius: 5px; font-weight: bold;">
                        Eliminar del carrito
                    </button>
                </div>
            </div>
        {{/each}}
        
        <div style="margin-top: 30px; background-color: #fff; border: 2px solid #4CAF50; border-radius: 8px; padding: 20px; text-align: right;">
            <span style="font-size: 1.4em; color: #333; margin-right: 15px;">Total de la compra:</span>
            <span style="font-size: 2em; color: #27ae60; font-weight: bold;">ARS ${{total}}</span>
        </div>

    {{else}}
        <div style="text-align: center; padding: 50px; background-color: #fff; border: 1px solid #ddd; border-radius: 8px;">
            <p style="font-size: 1.2em; color: #666;">El carrito está vacío, ¡agregá un auto!</p>
        </div>
    {{/if}}
</div>

<div style="margin-top: 40px; border-top: 2px solid #eaeaea; padding-top: 20px; text-align: center;">
    <a href="/products" style="text-decoration: none; padding: 12px 25px; background-color: #4CAF50; color: white; border-radius: 5px; font-weight: bold; font-size: 1em; cursor: pointer;">
        Volver a la lista de autos
    </a>
</div>

<script>
    async function eliminarDelCarrito(autoId) {
        const cartId = localStorage.getItem('cartId');
        if (!cartId || !confirm("¿Querés sacar este auto del carrito?")) return;

        try {
            // Llamamos al DELETE de tu API
            const response = await fetch(`/api/carts/${cartId}/products/${autoId}`, {
                method: 'DELETE'
            });

            if (response.ok) {
                // Recargamos la pantalla para ver el carrito actualizado
                window.location.reload(); 
            } else {
                alert('Hubo un error al eliminar el auto.');
            }
        } catch (error) {
            console.error('Error:', error);
        }
    }
</script>